# ── Database ──────────────────────────────────────────────────────────────────
# Use container service name "laundry_db" when running via docker-compose
DATABASE_URL=postgresql://postgres:password@laundry_db:5432/tflow

# ── Auth ──────────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:6969

# ── Server ────────────────────────────────────────────────────────────────────
PORT=6969
CORS_ORIGIN=http://localhost:5173
NODE_ENV=production

# ── Postgres (used by docker-compose for the DB container) ────────────────────
POSTGRES_PASSWORD=password
